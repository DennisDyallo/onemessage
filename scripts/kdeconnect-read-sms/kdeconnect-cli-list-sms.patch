# EXISTING (line 77):
#     parser.addOption(QCommandLineOption(QStringLiteral("send-sms"), i18n("Sends an SMS. Requires destination"), i18n("message")));
#
# ADD immediately after:
+    parser.addOption(QCommandLineOption(QStringLiteral("list-sms"), i18n("List SMS conversations on device")));

# ─────────────────────────────────────────────────────────────────────────────
# CHANGE 2 — Implementation block
# Location: after the closing brace of the --send-sms else-if block (~line 510)
#           before the next else-if block
# ─────────────────────────────────────────────────────────────────────────────

+   } else if (parser.isSet(QStringLiteral("list-sms"))) {
+       QString device = getDevice(iface, parser);
+       if (device.isEmpty())
+           return 1;
+
+       DeviceConversationsDbusInterface conversationsIface(device);
+       QDBusReply<QVariantList> reply = conversationsIface.activeConversations();
+
+       if (!reply.isValid()) {
+           QTextStream(stderr) << i18n("Error retrieving SMS conversations: %1",
+                                       reply.error().message()) << Qt::endl;
+           return 1;
+       }
+
+       const QVariantList conversations = reply.value();
+       if (conversations.isEmpty()) {
+           QTextStream(stdout) << i18n("No SMS conversations found. "
+               "Make sure KDE Connect is open on your phone and SMS sync is enabled.")
+               << Qt::endl;
+       } else {
+           for (const QVariant &v : conversations) {
+               const ConversationMessage msg =
+                   qdbus_cast<ConversationMessage>(v.value<QDBusArgument>());
+               QTextStream(stdout) << QStringLiteral("- ") << msg.address()
+                                   << QStringLiteral(": ") << msg.body() << Qt::endl;
+           }
+       }

