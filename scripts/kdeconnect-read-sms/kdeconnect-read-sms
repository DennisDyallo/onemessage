#!/usr/bin/env python3
"""
kdeconnect-read-sms — Read SMS conversations from paired Android device via KDE Connect DBus.

Part of the onemessage project. Bridges the KDE Connect daemon's DBus interface to stdout,
enabling the onemessage SMS provider to support inbox reading.

Usage:
  kdeconnect-read-sms                    # list all conversations (latest message preview)
  kdeconnect-read-sms --unread           # show only unread conversations
  kdeconnect-read-sms --thread +46...    # show last message for matching contact/number
  kdeconnect-read-sms --refresh          # request fresh data from phone, then list
  kdeconnect-read-sms --json             # output as JSON array (all other flags still apply)
  kdeconnect-read-sms --json --unread    # JSON array of unread conversations only

JSON output schema (one object per conversation):
  {
    "contact":    string,   // phone number or contact name from Android
    "preview":    string,   // last message body text
    "timestamp":  string,   // ISO 8601, e.g. "2026-04-09T00:41:12"
    "direction":  "in"|"out",
    "read":       boolean,
    "thread_id":  integer   // stable ID — use to request full conversation history
  }

Requires: brew install dbus && pip3 install dbus-python
"""

import sys
import os
import glob
import json
import time
import argparse
from datetime import datetime

# ── Find KDE Connect DBus socket ──────────────────────────────────────────────

def find_kdeconnect_socket():
    """
    Locate the KDE Connect bundled dbus-daemon socket in /tmp.

    KDE Connect ships its own dbus-daemon, creating a socket at /tmp/dbus-<random>.
    We verify the found socket actually has org.kde.kdeconnect registered to avoid
    connecting to an unrelated DBus session if multiple sockets exist.
    """
    sockets = glob.glob("/tmp/dbus-*")
    if not sockets:
        sys.exit("Error: No DBus sockets found in /tmp. Is KDE Connect running?")

    for path in sorted(sockets, key=os.path.getmtime, reverse=True):
        try:
            import dbus
            bus = dbus.bus.BusConnection(f"unix:path={path}")
            dbus_obj = bus.get_object("org.freedesktop.DBus", "/org/freedesktop/DBus")
            dbus_iface = dbus.Interface(dbus_obj, "org.freedesktop.DBus")
            names = [str(n) for n in dbus_iface.ListNames()]
            if "org.kde.kdeconnect" in names:
                return path
        except Exception:
            continue

    sys.exit(
        "Error: No DBus socket with org.kde.kdeconnect found. "
        "Is KDE Connect running? Try launching it from Applications."
    )

# ── Connect to DBus ───────────────────────────────────────────────────────────

def get_bus(socket_path):
    try:
        import dbus
        return dbus.bus.BusConnection(f"unix:path={socket_path}")
    except ImportError:
        sys.exit(
            "Error: dbus-python not installed.\n"
            "Fix: brew install dbus && pip3 install dbus-python"
        )
    except Exception as e:
        sys.exit(f"Error connecting to KDE Connect DBus at {socket_path}: {e}")

def get_device(bus):
    """Return the first paired and reachable device ID."""
    import dbus
    try:
        daemon = bus.get_object("org.kde.kdeconnect", "/modules/kdeconnect")
        daemon_iface = dbus.Interface(daemon, "org.kde.kdeconnect.daemon")
        devices = daemon_iface.devices(True, True)  # paired=True, reachable=True
        if not devices:
            sys.exit(
                "Error: No paired and reachable devices found.\n"
                "Make sure your phone is on the same network or connected via Tailscale, "
                "and that KDE Connect is open on Android."
            )
        return str(devices[0])
    except dbus.DBusException as e:
        sys.exit(f"Error querying KDE Connect daemon: {e}")

def get_conversations_iface(bus, device_id):
    import dbus
    obj = bus.get_object(
        "org.kde.kdeconnect",
        f"/modules/kdeconnect/devices/{device_id}"
    )
    return dbus.Interface(obj, "org.kde.kdeconnect.device.conversations")

# ── Data parsing ──────────────────────────────────────────────────────────────

def parse_conversation(conv):
    """
    Parse a DBus conversation struct returned by activeConversations().

    Struct layout (verified against live KDE Connect output, protocol v8):
      [0] int32  — message type flag
      [1] string — last message body text
      [2] array  — list of structs { string: address/contact name }
      [3] int64  — timestamp of last message (Unix milliseconds)
      [4] int32  — direction: 1=incoming, 2=outgoing
      [5] int32  — read status: 0=unread, 1=read
      [6] int64  — conversation/thread ID
      [7] int32  — sub-ID
      [8] int64  — thread count or related ID
      [9] array  — attachments (usually empty)
    """
    try:
        addresses = [str(a[0]) for a in conv[2]] if conv[2] else ["unknown"]
        timestamp_ms = int(conv[3])
        timestamp = datetime.fromtimestamp(timestamp_ms / 1000)
        return {
            "contact":   ", ".join(addresses),
            "preview":   str(conv[1]).strip(),
            "timestamp": timestamp,
            "direction": "in" if int(conv[4]) == 1 else "out",
            "read":      int(conv[5]) == 1,
            "thread_id": int(conv[6]),
        }
    except Exception:
        return None

# ── Serialization ─────────────────────────────────────────────────────────────

def to_json_obj(conv):
    """Convert a parsed conversation dict to a JSON-serializable object."""
    return {
        "contact":   conv["contact"],
        "preview":   conv["preview"],
        "timestamp": conv["timestamp"].isoformat(),
        "direction": conv["direction"],
        "read":      conv["read"],
        "thread_id": conv["thread_id"],
    }

# ── Display ───────────────────────────────────────────────────────────────────

def fmt_time(dt):
    now = datetime.now()
    if dt.date() == now.date():
        return dt.strftime("%H:%M")
    elif (now - dt).days < 7:
        return dt.strftime("%a %H:%M")
    else:
        return dt.strftime("%Y-%m-%d")

def print_conversations(convs):
    """Render pre-filtered, pre-sorted conversations as a human-readable table."""
    if not convs:
        print("No conversations found. Try --refresh to fetch from phone.")
        return

    print(f"\n{'CONTACT':<30} {'TIME':<12} {'RD':<4} {'PREVIEW'}")
    print("─" * 100)
    for c in convs:
        direction = "→" if c["direction"] == "out" else "←"
        read_mark = " " if c["read"] else "●"
        preview = c["preview"][:55].replace("\n", " ")
        print(f"{c['contact']:<30} {fmt_time(c['timestamp']):<12} {read_mark:<4} {direction} {preview}")
    print(f"\n{len(convs)} conversation(s)")

# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Read SMS conversations from KDE Connect paired device"
    )
    parser.add_argument(
        "--thread", metavar="CONTACT",
        help="Show last message for conversations matching CONTACT (name or number)"
    )
    parser.add_argument(
        "--unread", action="store_true",
        help="Show only unread conversations"
    )
    parser.add_argument(
        "--refresh", action="store_true",
        help="Request fresh conversation data from phone before listing (adds ~3s delay)"
    )
    parser.add_argument(
        "--device", metavar="ID",
        help="KDE Connect device ID (auto-detected if omitted)"
    )
    parser.add_argument(
        "--socket", metavar="PATH",
        help="DBus socket path (auto-detected from /tmp/dbus-* if omitted)"
    )
    parser.add_argument(
        "--json", action="store_true",
        help="Output as JSON array to stdout. Errors go to stderr. Composes with --unread and --thread."
    )
    args = parser.parse_args()

    socket_path = args.socket or find_kdeconnect_socket()
    bus = get_bus(socket_path)
    device_id = args.device or get_device(bus)
    iface = get_conversations_iface(bus, device_id)

    if args.refresh:
        if not args.json:
            print("Requesting fresh conversations from phone...", flush=True)
        try:
            iface.requestAllConversationThreads()
            time.sleep(3)
            if not args.json:
                print("Done.")
        except Exception as e:
            print(f"Warning: refresh request failed: {e}", file=sys.stderr)

    raw = iface.activeConversations()
    convs = [parse_conversation(c) for c in raw]
    filtered = [c for c in convs if c is not None]

    if args.unread:
        filtered = [c for c in filtered if not c["read"]]

    if args.thread:
        query = args.thread.lower()
        filtered = [c for c in filtered if query in c["contact"].lower()]

    filtered.sort(key=lambda c: c["timestamp"], reverse=True)

    if args.json:
        print(json.dumps([to_json_obj(c) for c in filtered], ensure_ascii=False, indent=2))
        return

    if args.thread and not filtered:
        print(f"No conversation found matching '{args.thread}'", file=sys.stderr)
        print("\nAvailable contacts:", file=sys.stderr)
        all_sorted = sorted([c for c in convs if c], key=lambda x: x["timestamp"], reverse=True)
        for c in all_sorted:
            print(f"  {c['contact']}", file=sys.stderr)
        return

    if args.thread:
        for m in filtered:
            direction_label = "received" if m["direction"] == "in" else "sent"
            print(f"\nThread: {m['contact']}")
            print(f"Last message ({fmt_time(m['timestamp'])}, {direction_label}):")
            print(f"  {m['preview']}")
    else:
        print_conversations(filtered)

if __name__ == "__main__":
    main()
